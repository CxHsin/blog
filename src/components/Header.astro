---
import { localizedPath, useTranslations } from '@/i18n/ui'

import { Icon } from 'astro-pure/user'
import config from '@/site-config'

const lang = 'zh'
const t = useTranslations(lang)

const menuKeyMap: Record<string, Parameters<typeof t>[0]> = {
  '/blog': 'nav.blog',
  '/archive': 'nav.notes',
  '/curated': 'nav.curated',
  '/projects': 'nav.projects',
  '/links': 'nav.links',
  '/about': 'nav.about',
  '/contact': 'nav.contact'
}

const menu = (config.header?.menu ?? []).map((item) => {
  const key = menuKeyMap[item.link]
  return {
    title: key ? t(key) : item.title,
    link: localizedPath(item.link, lang)
  }
})

const homeHref = localizedPath('/', lang)
const searchHref = localizedPath('/search', lang)
const currentPath = Astro.url.pathname
---

<svg class='header-distortion-defs' aria-hidden='true' focusable='false'>
  <defs>
    <filter
      id='warp'
      x='-20%'
      y='-20%'
      width='140%'
      height='140%'
      color-interpolation-filters='sRGB'
    >
      <feTurbulence
        type='fractalNoise'
        baseFrequency='0.012'
        numOctaves='1'
        seed='2'
        result='noise'
      />
      <feDisplacementMap
        in='SourceGraphic'
        in2='noise'
        scale='20'
        xChannelSelector='R'
        yChannelSelector='G'
      />
    </filter>
    <filter
      id='warp-panel'
      x='-20%'
      y='-20%'
      width='140%'
      height='140%'
      color-interpolation-filters='sRGB'
    >
      <feTurbulence
        type='fractalNoise'
        baseFrequency='0.02'
        numOctaves='1'
        seed='2'
        result='noise'
      />
      <feDisplacementMap
        in='SourceGraphic'
        in2='noise'
        scale='60'
        xChannelSelector='R'
        yChannelSelector='G'
      />
    </filter>
  </defs>
</svg>

<header-component
  class='group sticky top-4 z-[70] mb-12 flex items-center justify-between rounded-xl border border-transparent px-4 max-sm:py-1 sm:rounded-2xl'
>
  <a
    class='header-brand z-30 text-xl font-semibold'
    href={homeHref}
    aria-label='Brand'>{config.title}</a
  >

  <div class='flex items-center gap-x-2'>
    {/* Menu links */}
    <div
      id='headerExpandContent'
      class='end-0 start-0 top-12 grid border border-transparent group-[.not-top]:rounded-xl group-[.expanded]:opacity-100 max-sm:absolute max-sm:opacity-0 max-sm:group-[.not-top]:border-border max-sm:group-[.expanded.not-top]:bg-background max-sm:group-[.not-top]:px-4 max-sm:group-[.not-top]:py-2 sm:grid-rows-1'
    >
      <div class='flex flex-col items-center justify-center overflow-hidden sm:flex-row'>
        {
          menu.map((item) => (
            <a
              href={item.link}
              class='header-link w-full flex-none grow py-2 text-right font-medium transition-none sm:w-fit sm:px-3'
              aria-label='Nav menu item'
              aria-current={item.link === currentPath ? 'page' : undefined}
            >
              {item.title}
            </a>
          ))
        }
        <div class='flex w-full grow flex-row justify-end gap-x-3 sm:w-fit sm:gap-x-5'>
          <a class='header-icon-link px-1 py-2 transition-none sm:px-2' href={searchHref} title={t('nav.search')}>
            <span class='sr-only'>{t('nav.search')}</span>
            <Icon name='search' class='size-5' />
          </a>
        </div>
      </div>
    </div>

    {/* buttons */}
    <div class='z-30 flex gap-x-4'>
      <button
        id='toggleDevMode'
        class='header-action group/dev box-content h-5 rounded-md border p-1.5 font-mono text-xs leading-5 tracking-tight text-muted-foreground transition-colors sm:group-[.not-top]:rounded-xl'
        aria-label='Enter dev mode'
        title='Dev mode (press ` to open)'
      >
        <span aria-hidden='true'>$_</span>
      </button>
      <button
        id='toggleDarkMode'
        class='header-action group/dark box-content size-5 rounded-md border p-1.5 transition-colors sm:group-[.not-top]:rounded-xl'
      >
        <span class='sr-only'>{t('nav.toggleDarkMode')}</span>
        <Icon class='system size-5 group-hover/dark:text-primary' name='computer' />
        <Icon class='light hidden size-5 group-hover/dark:text-primary' name='sun' />
        <Icon class='dark hidden size-5 group-hover/dark:text-primary' name='moon' />
      </button>
      <button
        id='toggleMenu'
        class='header-action rounded-md border p-1.5 transition-colors sm:hidden sm:group-[.not-top]:rounded-xl'
        aria-controls='headerExpandContent'
        aria-expanded='false'
      >
        <span class='sr-only'>{t('nav.toggleMenu')}</span>
        <Icon class='size-5' name='menu' />
      </button>
    </div>
  </div>
</header-component>

{/* Use inline to load icon quicker firstly */}
<script is:inline>
  (() => {
    const themes = ['system', 'dark', 'light']
    const DARK_COLOR = '#0B0B10'
    const LIGHT_COLOR = '#FCFCFD'

    function applyTheme(theme = localStorage.getItem('theme') || 'system') {
      const resolvedTheme =
        theme === 'system'
          ? window.matchMedia('(prefers-color-scheme: dark)').matches
            ? 'dark'
            : 'light'
          : theme

      document.documentElement.classList.toggle('dark', resolvedTheme === 'dark')
      document
        .querySelector('meta[name="theme-color"]')
        ?.setAttribute('content', resolvedTheme === 'dark' ? DARK_COLOR : LIGHT_COLOR)

      return theme
    }

    function cycleTheme() {
      const currentTheme = localStorage.getItem('theme') || 'system'
      const currentIndex = themes.indexOf(currentTheme)
      const nextTheme = themes[(currentIndex + 1) % themes.length]
      localStorage.setItem('theme', nextTheme)
      applyTheme(nextTheme)
      return nextTheme
    }

    function showToast(message) {
      document.dispatchEvent(new CustomEvent('toast', { detail: { message } }))
    }

    function bindHeader(header) {
      if (!(header instanceof HTMLElement)) return

      const darkModeBtn = header.querySelector('#toggleDarkMode')
      const devModeBtn = header.querySelector('#toggleDevMode')
      const toggleMenuBtn = header.querySelector('#toggleMenu')

      if (!(darkModeBtn instanceof HTMLElement) || !(toggleMenuBtn instanceof HTMLElement)) return

      if (header.dataset.bound === 'true') {
        darkModeBtn.dataset.theme = localStorage.getItem('theme') || 'system'
        return
      }

      header.dataset.bound = 'true'
      darkModeBtn.dataset.theme = localStorage.getItem('theme') || 'system'

      let preScrollY = window.scrollY

      const setMenuExpanded = (expanded) => {
        header.classList.toggle('expanded', expanded)
        toggleMenuBtn.setAttribute('aria-expanded', String(expanded))
      }

      const updateState = () => {
        header.classList.toggle('not-top', window.scrollY > 20)
        header.dataset.show = String(window.scrollY < 350 || window.scrollY < preScrollY)
        preScrollY = window.scrollY
      }

      const handleDocumentPointerDown = (event) => {
        if (!header.classList.contains('expanded')) return
        const target = event.target
        if (!(target instanceof Element)) return
        if (!header.contains(target)) {
          setMenuExpanded(false)
          return
        }
        if (target.closest('a, button')) return
        setMenuExpanded(false)
      }

      window.addEventListener('scroll', updateState, { passive: true })
      window.addEventListener('pageshow', updateState)
      window.addEventListener('load', updateState, { once: true })

      darkModeBtn.addEventListener('click', () => {
        const newTheme = cycleTheme()
        darkModeBtn.dataset.theme = newTheme
        showToast(`Switched to ${newTheme} theme`)
      })

      devModeBtn?.addEventListener('click', () => {
        window.dispatchEvent(new CustomEvent('joye:toggle-dev'))
      })

      toggleMenuBtn.addEventListener('click', () => {
        setMenuExpanded(!header.classList.contains('expanded'))
      })

      document.addEventListener('pointerdown', handleDocumentPointerDown)

      updateState()
      requestAnimationFrame(updateState)
    }

    function initHeaders() {
      document.querySelectorAll('header-component').forEach(bindHeader)
    }

    initHeaders()

    if (!window.__cxinHeaderPageLoadBound) {
      document.addEventListener('astro:page-load', initHeaders)
      window.__cxinHeaderPageLoadBound = true
    }
  })()
</script>

<style>
  .header-distortion-defs {
    position: fixed;
    width: 0;
    height: 0;
    pointer-events: none;
  }

  header-component {
    transition:
      padding 0.3s,
      transform 0.3s,
      margin-inline 0.3s,
      border 0.15s,
      background-color 0.15s,
      box-shadow 0.2s,
      backdrop-filter 0.2s;
    --header-saturation: 1.25;
    --header-panel-saturation: 1.35;

    &.not-top {
      border-color: hsl(var(--border) / 0.28);
      border-radius: 999px;
      background:
        linear-gradient(180deg, rgba(255, 255, 255, 0.42), rgba(255, 255, 255, 0.16)),
        hsl(var(--background) / 0.34);
      -webkit-backdrop-filter: blur(18px) saturate(var(--header-saturation, 1.25));
      backdrop-filter: blur(18px) saturate(var(--header-saturation, 1.25));
    }
    &[data-show='false']:not(.expanded) {
      transform: translateY(-5rem);
    }
  }

  @media (min-width: 800px) {
    header-component.not-top {
      margin-inline: 1rem;
    }
  }

  @media (max-width: 1024px) {
    header-component.not-top {
      margin-inline: 0.75rem;
    }
  }

  @media (max-width: 860px) {
    header-component.not-top {
      margin-inline: 0.5rem;
    }
  }

  :global(.dark) header-component {
    --header-saturation: 1.18;
  }

  .header-brand,
  .header-link,
  .header-icon-link,
  .header-action {
    border-color: transparent;
    border-radius: 0.9rem;
    transition:
      color 0.2s ease,
      background-color 0.2s ease,
      border-color 0.2s ease,
      box-shadow 0.2s ease,
      transform 0.2s ease,
      filter 0.2s ease;
  }

  .header-brand {
    color: hsl(var(--primary));
    white-space: nowrap;
    line-height: 1;
  }

  .header-link,
  .header-icon-link {
    color: hsl(var(--foreground) / 0.92);
  }

  header-component.not-top .header-brand,
  header-component.not-top .header-link,
  header-component.not-top .header-icon-link,
  header-component.not-top .header-action {
    position: relative;
    border-radius: 0.95rem;
  }

  .header-link:hover,
  .header-link:focus-visible,
  .header-icon-link:hover,
  .header-icon-link:focus-visible,
  .header-action:hover,
  .header-action:focus-visible,
  .header-brand:hover,
  .header-brand:focus-visible {
    color: hsl(var(--foreground));
    background: hsl(var(--foreground) / 0.06);
    border-color: transparent;
    box-shadow: none;
  }

  header-component.not-top .header-brand:hover,
  header-component.not-top .header-brand:focus-visible,
  header-component.not-top .header-link:hover,
  header-component.not-top .header-link:focus-visible,
  header-component.not-top .header-icon-link:hover,
  header-component.not-top .header-icon-link:focus-visible,
  header-component.not-top .header-action:hover,
  header-component.not-top .header-action:focus-visible {
    background:
      linear-gradient(180deg, rgba(255, 255, 255, 0.1), rgba(255, 255, 255, 0.03)),
      linear-gradient(180deg, rgba(255, 255, 255, 0.03), rgba(255, 255, 255, 0.01));
    border-color: rgba(255, 255, 255, 0.05);
    box-shadow: none;
    transform: translateY(-1px);
    filter: saturate(1.03);
  }

  .header-action:hover,
  .header-action:focus-visible {
    transform: translateY(-1px);
  }

  :global(.dark) .header-link:hover,
  :global(.dark) .header-link:focus-visible,
  :global(.dark) .header-icon-link:hover,
  :global(.dark) .header-icon-link:focus-visible,
  :global(.dark) .header-action:hover,
  :global(.dark) .header-action:focus-visible,
  :global(.dark) .header-brand:hover,
  :global(.dark) .header-brand:focus-visible {
    background: rgba(255, 255, 255, 0.06);
    border-color: transparent;
  }

  :global(.dark) header-component.not-top .header-brand:hover,
  :global(.dark) header-component.not-top .header-brand:focus-visible,
  :global(.dark) header-component.not-top .header-link:hover,
  :global(.dark) header-component.not-top .header-link:focus-visible,
  :global(.dark) header-component.not-top .header-icon-link:hover,
  :global(.dark) header-component.not-top .header-icon-link:focus-visible,
  :global(.dark) header-component.not-top .header-action:hover,
  :global(.dark) header-component.not-top .header-action:focus-visible {
    background:
      linear-gradient(180deg, rgba(255, 255, 255, 0.08), rgba(255, 255, 255, 0.02)),
      linear-gradient(180deg, rgba(255, 255, 255, 0.03), rgba(255, 255, 255, 0.01));
    border-color: rgba(255, 255, 255, 0.04);
    box-shadow: none;
  }

  :global(.dark) header-component.not-top {
    background:
      linear-gradient(180deg, rgba(255, 255, 255, 0.13), rgba(255, 255, 255, 0.04)),
      hsl(var(--background) / 0.38);
  }

  /* header menu */
  @media (max-width: 640px) {
    header-component {
      padding-left: 0.25rem;
      padding-right: 0.25rem;
    }

    header-component.not-top {
      margin-inline: 0;
      border-radius: 1.1rem;
      border-radius: 0.8rem;
    }

    #headerExpandContent {
      top: calc(100% + 0.5rem);
      grid-template-rows: 0fr;
      transition:
        opacity 0.3s,
        padding 0.3s,
        grid-template-rows 0.3s;
    }
    .expanded #headerExpandContent {
      grid-template-rows: 1fr;
    }
    .expanded.not-top #headerExpandContent {
      border-radius: 1.2rem;
      background:
        linear-gradient(180deg, rgba(255, 255, 255, 0.018), rgba(255, 255, 255, 0.004)),
        linear-gradient(135deg, hsl(var(--background) / 0.008), hsl(var(--background) / 0.003));
      box-shadow:
        0 1px 0 rgba(255, 255, 255, 0.28) inset,
        0 0 3px 1px rgba(255, 255, 255, 0.12) inset,
        0 12px 30px rgba(17, 17, 26, 0.16);
      -webkit-backdrop-filter: url(#warp-panel) saturate(var(--header-panel-saturation, 1.35));
      backdrop-filter: url(#warp-panel) saturate(var(--header-panel-saturation, 1.35));
    }

    .expanded.not-top #headerExpandContent > div {
      align-items: stretch;
      justify-content: flex-start;
      gap: 0.12rem;
      width: 100%;
      overflow: visible;
    }

    .expanded.not-top .header-link {
      width: 100%;
      margin-top: 0;
      margin-bottom: 0;
      padding: 0.72rem 0.85rem;
      border-radius: 0.9rem;
      font-size: 1rem;
      text-align: right;
    }

    .expanded.not-top .header-icon-link {
      display: flex;
      width: 100%;
      justify-content: flex-end;
      padding: 0.68rem 0.85rem;
      border-radius: 0.9rem;
    }

    /* header component after */
    header-component #headerExpandContent::after {
      box-sizing: content-box;
      content: '';
      position: absolute;
      inset-inline: calc(-1rem - 1px);
      bottom: 0;
      top: -5rem;
      z-index: -1;
      transition: 0.3s;
      visibility: hidden;
      opacity: 0;
      border-bottom: 1px solid transparent;
    }
    header-component:not(.not-top) #headerExpandContent::after {
      visibility: visible;
      bottom: -1rem;
      opacity: 1;
      background-color: hsl(var(--muted) / var(--un-bg-opacity, 1));
      border-bottom-color: hsl(var(--border) / var(--un-border-opacity, 1));
    }

    :global(.dark) .expanded.not-top #headerExpandContent {
      background:
        linear-gradient(180deg, rgba(255, 255, 255, 0.012), rgba(255, 255, 255, 0.003)),
        linear-gradient(135deg, rgba(42, 50, 63, 0.06), rgba(23, 29, 39, 0.03));
      box-shadow:
        0 1px 0 rgba(255, 255, 255, 0.08) inset,
        0 0 2px 1px rgba(255, 255, 255, 0.06) inset,
        0 12px 30px rgba(5, 8, 14, 0.24);
    }
  }

  /* dark light mode toggle */
  #toggleDarkMode {
    &[data-theme='dark'] {
      & .system {
        display: none;
      }
      & .dark {
        display: block;
      }
    }
    &[data-theme='light'] {
      & .system {
        display: none;
      }
      .light {
        display: block;
      }
    }
  }
</style>
