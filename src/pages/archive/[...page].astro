---
import type { GetStaticPaths, Page } from 'astro'
import type { CollectionEntry } from 'astro:content'
import { getSafeArchiveCollection } from '@/lib/content-guards'

import { Paginator } from 'astro-pure/components/pages'
import { Button, Icon } from 'astro-pure/user'
import PageLayout from '@/layouts/BaseLayout.astro'

export const prerender = true

export const getStaticPaths: GetStaticPaths = async ({ paginate }) => {
  const entries = (await getSafeArchiveCollection())
    .filter((entry) => !entry.data.draft)
    .sort((a, b) => b.data.date.getTime() - a.data.date.getTime())

  return paginate(entries, { pageSize: 20 })
}

interface Props {
  page: Page<CollectionEntry<'archive'>>
}

const { page } = Astro.props as unknown as Props
const allEntries = (await getSafeArchiveCollection()).filter((entry) => !entry.data.draft)
const uniqueTags = [...new Set(allEntries.flatMap((entry) => entry.data.tags))].sort()
const statusCounts = allEntries.reduce(
  (counts, entry) => {
    counts[entry.data.status] = (counts[entry.data.status] || 0) + 1
    return counts
  },
  {} as Record<string, number>
)

const typeLabels: Record<string, string> = {
  note: '笔记',
  snippet: '片段',
  draft: '草稿',
  idea: '想法',
  research: '研究',
  reference: '参考'
}

const statusLabels: Record<string, string> = {
  'in-progress': '进行中',
  incomplete: '未完成',
  ready: '已整理',
  archived: '已归档'
}

const statusColors: Record<string, string> = {
  'in-progress': 'bg-yellow-100 text-yellow-800 dark:bg-yellow-900/30 dark:text-yellow-300',
  incomplete: 'bg-red-100 text-red-800 dark:bg-red-900/30 dark:text-red-300',
  ready: 'bg-green-100 text-green-800 dark:bg-green-900/30 dark:text-green-300',
  archived: 'bg-gray-100 text-gray-600 dark:bg-gray-800/30 dark:text-gray-400'
}

const statusDotColors: Record<string, string> = {
  'in-progress': 'bg-yellow-500',
  incomplete: 'bg-red-500',
  ready: 'bg-green-500',
  archived: 'bg-gray-400'
}

const typeColors: Record<string, string> = {
  note: 'bg-blue-100 text-blue-700 dark:bg-blue-900/30 dark:text-blue-300',
  snippet: 'bg-purple-100 text-purple-700 dark:bg-purple-900/30 dark:text-purple-300',
  draft: 'bg-amber-100 text-amber-700 dark:bg-amber-900/30 dark:text-amber-300',
  idea: 'bg-pink-100 text-pink-700 dark:bg-pink-900/30 dark:text-pink-300',
  research: 'bg-teal-100 text-teal-700 dark:bg-teal-900/30 dark:text-teal-300',
  reference: 'bg-indigo-100 text-indigo-700 dark:bg-indigo-900/30 dark:text-indigo-300'
}

const meta = {
  description: '学习记录、工程思考与尚在生长中的知识笔记',
  title: page.currentPage === 1 ? 'Notes' : `Notes - Page ${page.currentPage}`
}

const paginationProps = {
  ...(page.url.prev && { prevUrl: { text: '← 上一页', url: page.url.prev } }),
  ...(page.url.next && { nextUrl: { text: '下一页 →', url: page.url.next } })
}
---

<PageLayout {meta}>
  <Button title='Back' href='/' style='back' />

  <main class='mt-6 lg:mt-10'>
    <div id='content-header' class='animate'>
      <h1 class='mb-2 text-3xl font-medium'>Notes</h1>
      <p class='text-muted-foreground'>学习记录、工程思考与尚在生长中的知识笔记。</p>
    </div>

    <div class='mt-10 grid gap-y-16 sm:grid-cols-[3fr_1fr] sm:gap-x-8'>
      <section id='content' class='animate' aria-label='Notes'>
        <ul class='flex flex-col gap-y-4 text-start'>
          {
            page.data.map((entry) => (
              <li>
                <a
                  href={`/archive/${entry.id}`}
                  class='group block rounded-xl border border-border bg-card px-5 py-5 transition hover:border-foreground/20 hover:shadow-sm'
                  data-astro-prefetch
                >
                  <div class='flex items-start justify-between gap-4'>
                    <div class='min-w-0 flex-1 space-y-2'>
                      <h2 class='text-lg font-medium leading-tight group-hover:text-foreground'>
                        {entry.data.title}
                      </h2>
                      {entry.data.description && (
                        <p class='text-sm leading-6 text-muted-foreground'>
                          {entry.data.description}
                        </p>
                      )}
                      <div class='flex flex-wrap items-center gap-2 text-xs text-muted-foreground'>
                        <span
                          class={`rounded-md px-2 py-0.5 font-medium ${typeColors[entry.data.type]}`}
                        >
                          {typeLabels[entry.data.type] || entry.data.type}
                        </span>
                        <time datetime={entry.data.date.toISOString()}>
                          {entry.data.date.toLocaleDateString('zh-CN')}
                        </time>
                        {entry.data.tags.map((tag) => (
                          <span class='rounded-md bg-muted px-2 py-0.5'>{tag}</span>
                        ))}
                      </div>
                    </div>
                    <span
                      class={`shrink-0 rounded-md px-2 py-1 text-xs font-medium ${statusColors[entry.data.status]}`}
                    >
                      {statusLabels[entry.data.status] || entry.data.status}
                    </span>
                  </div>
                </a>
              </li>
            ))
          }
        </ul>

        {
          page.lastPage > 1 && (
            <div class='mt-8'>
              <Paginator {...paginationProps} />
            </div>
          )
        }
      </section>

      <aside class='animate' id='sidebar'>
        {
          uniqueTags.length > 0 && (
            <section class='mb-8'>
              <div class='mb-4 flex items-center justify-between gap-3'>
                <h2 class='flex items-center text-lg font-semibold'>
                  <Icon name='tag-2' class='me-2' />
                  Tags
                </h2>
                <a href='/archive/tags' class='text-xs text-muted-foreground hover:text-foreground'>
                  查看全部 →
                </a>
              </div>
              <ul class='flex flex-wrap gap-2'>
                {uniqueTags.map((tag) => (
                  <li>
                    <Button title={tag} href={`/archive/tags/${tag}`} style='pill' />
                  </li>
                ))}
              </ul>
            </section>
          )
        }

        <section>
          <h2 class='mb-4 flex items-center text-lg font-semibold'>
            <Icon name='list' class='me-2' />
            Status
          </h2>
          <ul class='space-y-2 text-sm'>
            {
              Object.entries(statusCounts).map(([status, count]) => (
                <li class='flex items-center justify-between gap-3'>
                  <span class='flex items-center gap-2'>
                    <span
                      class={`size-2 rounded-full ${statusDotColors[status] || 'bg-gray-400'}`}
                    />
                    {statusLabels[status] || status}
                  </span>
                  <span class='text-xs text-muted-foreground'>{count}</span>
                </li>
              ))
            }
          </ul>
        </section>
      </aside>
    </div>
  </main>
</PageLayout>
