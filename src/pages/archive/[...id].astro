---
import { render, type CollectionEntry } from 'astro:content'
import { getSafeArchiveCollection, getSafeBlogCollection } from '@/lib/content-guards'

import { TOC } from 'astro-pure/components/pages'
import { Button, FormattedDate, Icon } from 'astro-pure/user'
import PageLayout from '@/layouts/ContentLayout.astro'
import PageInfo from '@/components/comment/PageInfo.astro'

export const prerender = true

export async function getStaticPaths() {
  const archives = await getSafeArchiveCollection()
  return archives.map((entry) => ({
    params: { id: entry.id },
    props: { entry }
  }))
}

type Props = {
  entry: CollectionEntry<'archive'>
}

const { entry } = Astro.props as Props
const { Content, headings, remarkPluginFrontmatter } = await render(entry)
const minutesRead = (remarkPluginFrontmatter as { minutesRead?: string }).minutesRead

const { title, description, date, updatedDate, tags, type, relatedBlog, relatedArchive, source } =
  entry.data

let relatedBlogPosts: CollectionEntry<'blog'>[] = []
if (relatedBlog && relatedBlog.length > 0) {
  const allBlogPosts = await getSafeBlogCollection()
  relatedBlogPosts = allBlogPosts.filter((post) => relatedBlog.includes(post.id))
}

let relatedArchiveEntries: CollectionEntry<'archive'>[] = []
if (relatedArchive && relatedArchive.length > 0) {
  const allArchives = await getSafeArchiveCollection()
  relatedArchiveEntries = allArchives.filter(
    (arch) => relatedArchive.includes(arch.id) && arch.id !== entry.id
  )
}

const typeLabels: Record<string, string> = {
  note: '📝 Note',
  snippet: '💡 Snippet',
  draft: '✏️ Draft',
  idea: '🔮 Idea',
  research: '🔬 Research',
  reference: '📚 Reference'
}

const meta = {
  title,
  description: description || title
}
---

<PageLayout {meta} back='/archive'>
  <TOC {headings} slot='sidebar' />

  <div slot='header' class='article-info animate'>
    <div class='flex flex-wrap gap-x-4 gap-y-2 text-xs leading-6 text-muted-foreground'>
      <span class='flex items-center gap-1'>
        <Icon name='calendar' class='size-5' />
        <FormattedDate class='font-sans' date={date} />
        {
          updatedDate && (
            <span>
              / Update <FormattedDate class='font-sans' date={updatedDate} />
            </span>
          )
        }
      </span>

      {
        minutesRead && (
          <span class='flex items-center gap-1'>
            <Icon name='time' class='size-5' />
            {minutesRead}
          </span>
        )
      }

      {
        tags.length > 0 && (
          <span class='flex items-center gap-1'>
            <Icon name='hashtag' class='size-5' />
            {tags.map((tag, index) => (
              <span>
                <a
                  href={`/archive/tags/${tag}`}
                  class='hover:underline hover:underline-offset-4'
                  data-pagefind-filter='tag'
                >
                  {tag}
                </a>
                {index < tags.length - 1 && ' / '}
              </span>
            ))}
          </span>
        )
      }
    </div>

    <h1 class='mt-4 text-2xl font-medium leading-tight sm:mb-2 sm:mt-6 sm:text-3xl'>{title}</h1>

    <div class='mt-3 italic'>
      {
        description && (
          <blockquote class='text-sm text-muted-foreground'>
            <q>{description}</q>
          </blockquote>
        )
      }
      <PageInfo class='mt-1' path={`/archive/${entry.id}`} />
    </div>

    {
      source && (
        <p class='mt-3 text-xs text-muted-foreground'>
          Source:{' '}
          <a href={source} target='_blank' rel='noopener noreferrer' class='hover:underline'>
            {source}
          </a>
        </p>
      )
    }

    <div class='mt-4 w-1/2 border-t sm:mt-6 sm:w-1/3'></div>
  </div>

  <article class='prose prose-pure dark:prose-invert max-w-none'>
    <Content />
  </article>

  <div slot='bottom' class='animate mt-8 border-t border-border pt-6'>
    {
      (relatedBlogPosts.length > 0 || relatedArchiveEntries.length > 0) && (
        <>
          <h2 class='mb-4 text-xl font-semibold'>Related Content</h2>

          {relatedBlogPosts.length > 0 && (
            <div class='mb-6'>
              <h3 class='mb-3 flex items-center gap-2 text-sm font-medium text-muted-foreground'>
                <span>📰</span>
                Blog Posts
              </h3>
              <ul class='space-y-2'>
                {relatedBlogPosts.map((post) => (
                  <li>
                    <a
                      href={`/blog/${post.id}`}
                      class='block rounded-lg border border-border bg-card p-3 transition hover:border-foreground/20'
                      data-astro-prefetch
                    >
                      <div class='font-medium'>{post.data.title}</div>
                      {post.data.description && (
                        <p class='mt-1 text-sm text-muted-foreground'>{post.data.description}</p>
                      )}
                    </a>
                  </li>
                ))}
              </ul>
            </div>
          )}

          {relatedArchiveEntries.length > 0 && (
            <div class='mb-6'>
              <h3 class='mb-3 flex items-center gap-2 text-sm font-medium text-muted-foreground'>
                <span>🗂️</span>
                Archive Entries
              </h3>
              <ul class='space-y-2'>
                {relatedArchiveEntries.map((arch) => (
                  <li>
                    <a
                      href={`/archive/${arch.id}`}
                      class='block rounded-lg border border-border bg-card p-3 transition hover:border-foreground/20'
                      data-astro-prefetch
                    >
                      <div class='flex items-center gap-2'>
                        <span class='font-medium'>{arch.data.title}</span>
                        <span class='text-xs text-muted-foreground'>
                          {typeLabels[arch.data.type] || arch.data.type}
                        </span>
                      </div>
                      {arch.data.description && (
                        <p class='mt-1 text-sm text-muted-foreground'>{arch.data.description}</p>
                      )}
                    </a>
                  </li>
                ))}
              </ul>
            </div>
          )}
        </>
      )
    }

    <div class='flex items-start justify-between gap-4 border-t border-border pt-6'>
      <div class='text-sm text-muted-foreground'>
        <p class='mb-2 flex items-center gap-2'>
          <span class='shrink-0'>🗂️</span>
          <span>This is a {typeLabels[type]?.toLowerCase() || type} in the knowledge base.</span>
        </p>
        <p class='text-xs'>Content may be incomplete or work-in-progress.</p>
      </div>
      <Button title='← Back' href='/archive' style='back' />
    </div>
  </div>
</PageLayout>
