---
import type { GetStaticPaths } from 'astro'
import { Button, Card } from 'astro-pure/user'
import PageLayout from '@/layouts/BaseLayout.astro'

export const prerender = true
export const getStaticPaths = (() => [{ params: { page: undefined } }]) satisfies GetStaticPaths

const meta = {
  description: 'Blog template page',
  title: 'Blog'
}
---

<PageLayout {meta}>
  <Button title='Back' href='/' style='back' />
  <main class='mt-6 lg:mt-10'>
    <div id='content-header' class='animate'>
      <h1 class='mb-6 mt-6 text-3xl font-medium sm:mt-10'>Blog</h1>
    </div>

    <section id='content' class='animate'>
      <Card heading='Blank template' subheading='The original personal blog list has been removed.'>
        <p class='text-muted-foreground'>Use this page later for your own posts, notes, announcements, or any writing archive you want to publish.</p>
      </Card>
    </section>
  </main>
</PageLayout>
