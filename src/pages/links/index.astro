---
import { Collapse, Timeline } from 'astro-pure/user'
import PageLayout from '@/layouts/CommonPage.astro'
import Comment from '@/components/comment/Comment.astro'
import FriendConstellation from '@/components/links/FriendConstellation.astro'
import FriendList from '@/components/links/FriendList.astro'
import meAvatar from '@/assets/avatar.jpg'
import { theme } from '@/site-config'

const headings = [
  { depth: 2, slug: 'friend-links', text: 'Friend Links' },
  { depth: 2, slug: 'apply-links', text: 'Apply Links' }
]

const friends = [
  {
    id_name: 'friend-links',
    desc: 'Friends I exchange blog links with',
    link_list: [
      {
        name: "YinFeng's Blog",
        intro: 'windchant.online',
        link: 'https://www.windchant.online/',
        avatar: 'https://www.windchant.online/favicon/favicon.ico',
        met: '互换友链',
        since: '2026-06-28'
      },
      {
        name: "Cooing's Blog",
        intro: 'Cooing 维护的像素个人站，用于长文、笔记、日志和项目整理。',
        link: 'https://blog.cooingcode.space',
        avatar: 'https://blog.cooingcode.space/avatar.svg',
        met: '互换友链',
        since: '2026-06-25'
      },
      {
        name: 'Joshua Chen Personal Blog',
        intro: 'AI Agent & Full-Stack Developer',
        link: 'https://blog.joshua2008.top/',
        avatar: 'https://blog.joshua2008.top/favicon/apple-touch-icon.png',
        met: '互换友链',
        since: '2026-06-25'
      },
      {
        name: 'Joye Personal Blog',
        intro: 'Stay hungry, stay foolish',
        link: 'https://joyehuang.me/',
        avatar: 'https://joyehuang.me/favicon/favicon.ico',
        met: '互换友链',
        since: '2026-06-24'
      }
    ]
  },
  {
    id_name: 'inactive-links',
    desc: 'Inactive or rule-breaking friends',
    link_list: []
  }
]

const logbook = [
  {
    date: '2026-06-28',
    content:
      '添加 <a href="https://www.windchant.online/" target="_blank" rel="noopener noreferrer">YinFeng\'s Blog</a>。'
  },
  {
    date: '2026-06-25',
    content:
      '添加 <a href="https://blog.cooingcode.space" target="_blank" rel="noopener noreferrer">Cooing\'s Blog</a> 与 <a href="https://blog.joshua2008.top/" target="_blank" rel="noopener noreferrer">Joshua Chen Personal Blog</a>。'
  },
  {
    date: '2026-06-24',
    content:
      '收到首位友链：<a href="https://joyehuang.me/" target="_blank" rel="noopener noreferrer">Joye Personal Blog</a>。'
  },
  {
    date: '2026-06-22',
    content: '友链页面就绪，等待第一位朋友。'
  }
]

const applyTip = [
  { name: 'Name', val: theme.title },
  { name: 'Desc', val: theme.description || 'Null' },
  { name: 'Link', val: 'https://cxin.vercel.app/' },
  { name: 'Avatar', val: 'https://cxin.vercel.app/favicon/android-chrome-512x512.png' }
]

const allApplyText = applyTip.map(({ name, val }) => `${name}: ${val}`).join('\n')
const copyAllScript = `navigator.clipboard.writeText(${JSON.stringify(allApplyText)});document.dispatchEvent(new CustomEvent('toast',{detail:{message:'已复制全部信息到剪贴板'}}))`
---

<PageLayout title='Links' {headings} info='/links'>
  <h2 id='friend-links'>Friend Links</h2>
  <p>朋友是天上的星，你在中央。每条线是一段连接。把鼠标移到星上看 ta 是谁。</p>
  <FriendConstellation list={friends[0]} meAvatar={meAvatar} meLabel='cxin.vercel.app' />

  <Collapse title='Links with Bad Status'>
    <FriendList list={friends[1]} />
  </Collapse>

  <Collapse title='Link History Book'>
    <Timeline events={logbook} />
  </Collapse>

  <h2 id='apply-links'>Apply Links</h2>
  <p>
    本站信息如下 The site information（点击单行复制，或
    <button
      type='button'
      class='cursor-pointer underline underline-offset-4'
      onclick={copyAllScript}
    >
      一键复制全部
    </button>
    ）：
  </p>

  <blockquote class='not-prose grid grid-cols-[auto_1fr] gap-x-2 break-words border-s-4 ps-4'>
    {
      applyTip.map(({ name, val }) => {
        const script = `navigator.clipboard.writeText('${val}');document.dispatchEvent(new CustomEvent('toast',{detail:{message:'Copied "${val}" to clipboard!'}}))`
        return (
          <>
            <span class='text-end'>{name}:</span>
            <samp class='cursor-pointer' onclick={script}>
              {val}
            </samp>
          </>
        )
      })
    }
  </blockquote>

  <p>几点小说明：</p>
  <ul>
    <li>在你的友链上添加了本站；</li>
    <li>请确保你的站点活着；</li>
    <li>博客内容不违反国家法律。</li>
  </ul>

  <Comment slot='bottom' />
</PageLayout>
