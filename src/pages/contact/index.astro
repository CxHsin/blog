---
import PageLayout from '@/layouts/CommonPage.astro'

const headings = [
  { depth: 2, slug: 'contact-way', text: 'Contact' },
  { depth: 2, slug: 'todo', text: 'To-do' }
]
---

<PageLayout title='Contact' {headings} info='/contact'>
  <p>This page is now a blank template. The original personal contact details have been removed.</p>

  <h2 id='contact-way'>Contact</h2>
  <ul>
    <li><strong>Email</strong>: to be added</li>
    <li><strong>WeChat / Telegram / other socials</strong>: to be added</li>
    <li><strong>Preferred contact method</strong>: to be added</li>
  </ul>

  <h2 id='todo'>To-do</h2>
  <ul>
    <li>How people should reach you</li>
    <li>Whether you accept collaboration, networking, referrals, or project invites</li>
    <li>What info to include when contacting you, such as intent or project background</li>
  </ul>
</PageLayout>
