---
import PageLayout from '@/layouts/CommonPage.astro'
import GitHubContributions from '@/components/projects/GitHubContributions.astro'
import ProjectSection from '@/components/projects/ProjectSection.astro'

const headings = [
  { depth: 2, slug: 'open-source', text: 'Open Source' },
  { depth: 2, slug: 'programs', text: 'Programs' },
  { depth: 2, slug: 'learnings', text: 'Learnings' },
  { depth: 2, slug: 'theme', text: 'Theme' }
]

const openSource = [
  {
    name: 'Coming soon',
    description: 'Open-source projects will be added here later.',
    links: [{ type: 'github', href: 'https://github.com/CxHsin' }]
  }
]

const programs = [
  {
    name: 'flow-ai',
    description: '面向协作式 AI 工作流的系统设计空间，聚焦流程组织、任务编排与多人协作体验。',
    links: [
      { type: 'github', href: 'https://github.com/CxHsin/flow-ai' },
      { type: 'site', href: 'https://ghost-ai-eight-rouge.vercel.app/' }
    ]
  },
  {
    name: 'jarvis-agent',
    description: '一个面向个人助手场景的 Agent 项目，探索记忆、工具调用与持续任务执行。',
    links: [{ type: 'github', href: 'https://github.com/CxHsin/jarvis-agent' }]
  }
]

const learnings = [
  {
    name: 'CSAPP',
    description:
      '围绕《Computer Systems: A Programmer’s Perspective》整理的系统学习笔记与练习记录。',
    links: [{ type: 'github', href: 'https://github.com/CxHsin/csapp' }]
  },
  {
    name: 'UCB CS61A',
    description: 'UCB CS61A 课程相关的学习整理，覆盖概念理解、代码练习与阶段性复盘。',
    links: [{ type: 'github', href: 'https://github.com/CxHsin/CS61A' }]
  }
]

const theme = [
  {
    name: 'Astro-theme-pure',
    description: '基于 Astro 的博客主题，强调简洁排版、内容阅读体验与可扩展的个人站点结构。',
    links: [{ type: 'github', href: 'https://github.com/cworld1/astro-theme-pure' }]
  }
]
---

<PageLayout title='Projects' {headings} info={{ slug: '/projects', hideComment: true }}>
  <p>GitHub Activities</p>
  <GitHubContributions username='CxHsin' displayName='CxHsin' />

  <h2 id='open-source'>Open Source</h2>
  <ProjectSection project={openSource} />

  <h2 id='programs'>Programs</h2>
  <ProjectSection project={programs} />

  <h2 id='learnings'>Learnings</h2>
  <ProjectSection class='my-2' project={learnings} />

  <h2 id='theme'>Theme</h2>
  <ProjectSection project={theme} />
</PageLayout>
