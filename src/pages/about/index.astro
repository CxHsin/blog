---
import { Button, Card } from 'astro-pure/user'
import PageLayout from '@/layouts/CommonPage.astro'

const headings = [
  { depth: 2, slug: 'overview', text: 'Overview' },
  { depth: 2, slug: 'todo', text: 'To-do' }
]
---

<PageLayout title='About' {headings} info='/about'>
  <h2 id='overview'>Overview</h2>
  <p>This page is now a blank template. Personal profile details from the original site have been removed.</p>
  <p>Use this space for a short introduction, your current focus, background, and anything else you want visitors to know.</p>
  <Button title='View contact page' class='w-fit' href='/contact' style='ahead' />

  <h2 id='todo'>To-do</h2>
  <Card heading='Fill this section later' subheading='Suggested placeholders for your own content.'>
    <ul class='ms-4 list-disc text-muted-foreground'>
      <li>Short self introduction</li>
      <li>School / company / city</li>
      <li>Current focus</li>
      <li>Experience summary</li>
    </ul>
  </Card>
</PageLayout>
