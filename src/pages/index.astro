---
import { Image } from 'astro:assets'
import avatar from 'src/assets/avatar.jpg'

import { Quote } from 'astro-pure/advanced'
import { Button, Card, Icon, Label } from 'astro-pure/user'
import PageLayout from '@/layouts/BaseLayout.astro'
import Section from '@/components/home/Section.astro'
import SkillLayout from '@/components/home/SkillLayout.astro'
import Terminal from '@/components/terminal/Terminal.astro'
import config from '@/site-config'

export const prerender = true

const languages = ['TypeScript', 'JavaScript', 'Python', 'SQL']
const frontend = ['React', 'Next.js', 'Tailwind CSS', 'Vite']
const backend = ['Node.js', 'Supabase', 'Vercel', 'PostgreSQL']
const ai = ['LLM', 'Agent', 'RAG', 'Prompt Engineering']
const tools = ['Git', 'Docker', 'Bun', 'Figma']

---

<PageLayout meta={{ title: 'Home' }} highlightColor='#659EB9'>
  <main class='flex w-full flex-col items-center'>
    <section class='animate relative z-50 mb-12 flex flex-col items-center gap-y-6' id='content-header'>
      <Image
        src={avatar}
        alt='profile'
        class='h-28 w-auto rounded-full border p-1'
        loading='eager'
      />

      <div class='flex flex-col items-center gap-y-4'>
        <h1 class='text-3xl font-bold'>{config.author}</h1>
        <div class='flex flex-wrap justify-center gap-x-7 gap-y-3'>
          <Label title='GitHub' as='a' href='https://github.com/CxHsin' target='_blank'>
            <Icon name='github' class='size-5' slot='icon' />
          </Label>
        </div>
      </div>

      <div class='flex flex-row gap-3'>
        <a
          href='/contact'
          class='flex flex-row items-center gap-x-3 rounded-full border bg-background px-4 py-2 text-sm shadow-sm transition-shadow hover:shadow-md'
        >
          <span class='relative flex items-center justify-center'>
            <span
              class='absolute size-2 animate-ping rounded-full border border-green-400 bg-green-400 opacity-75'
            ></span>
            <span class='size-2 rounded-full bg-green-400'></span>
          </span>
          <p class='font-medium text-muted-foreground'>Contact me</p>
        </a>
      </div>
    </section>

    <div
      id='content'
      class='animate relative z-0 flex w-full min-w-0 max-w-full flex-col gap-y-10 md:w-4/5 lg:w-5/6'
    >
      <div class='-mt-2'>
        <Terminal />
      </div>

      <Section title='About'>
        <p>Put a short bio here, such as your focus area, role, or long-term interests.</p>
        <p>Add your own background, current work, school, company, location, or contact details here later.</p>
        <Button title='See more' class='w-fit self-end text-sm' href='/about' style='ahead' />
      </Section>

      <Section title='Blog'>
        <Card heading='Blank template' subheading='The original personal blog content has been removed.'>
          <p class='text-muted-foreground'>You can add your own posts here later.</p>
        </Card>
        <Button title='Open page' class='w-fit self-end text-sm' href='/blog' style='ahead' />
      </Section>

      <Section title='Notes'>
        <Card heading='Blank template' subheading='The original personal notes content has been removed.'>
          <p class='text-muted-foreground'>You can add your own notes or drafts here later.</p>
        </Card>
        <Button title='Open page' class='w-fit self-end text-sm' href='/archive' style='ahead' />
      </Section>

      <Section title='Projects'>
        <Card heading='Blank template' subheading='The original personal project content has been removed.'>
          <p class='text-muted-foreground'>You can add your own selected projects here later.</p>
        </Card>
        <Button title='Open page' class='w-fit self-end text-sm' href='/projects' style='ahead' />
      </Section>

      <Section title='Profile Template'>
        <Card
          heading='To be filled'
          subheading='You can replace these placeholders later. For now, they stay as a template.'
          class='rounded-2xl px-6 py-5'
        >
          <ul class='ms-4 list-disc text-muted-foreground'>
            <li>One-line bio</li>
            <li>School / company / city</li>
            <li>Common contact methods</li>
            <li>Long-term focus areas</li>
          </ul>
        </Card>
      </Section>

      <Section title='Skills'>
        <SkillLayout title='Languages' skills={languages} />
        <SkillLayout title='Frontend' skills={frontend} />
        <SkillLayout title='Backend' skills={backend} />
        <SkillLayout title='AI / Agent' skills={ai} />
        <SkillLayout title='Tools' skills={tools} />
      </Section>
    </div>

    <Quote class='mt-12' />
  </main>
</PageLayout>
